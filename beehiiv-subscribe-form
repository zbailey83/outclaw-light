      overflow: hidden;
    }

    /* subtle glow blob behind card */
    .card::before {
      content: '';
      position: absolute;
      inset: -60px;
      background: radial-gradient(circle at 50% 0%, rgba(232,255,71,.07) 0%, transparent 70%);
      pointer-events: none;
    }

    /* ── Label / eyebrow ──────────────────────────── */
    .eyebrow {
      display: inline-flex;
      align-items: center;
      gap: .45rem;
      font-size: .7rem;
      letter-spacing: .14em;
      text-transform: uppercase;
      color: var(--accent);
      margin-bottom: 1.1rem;
    }
    .eyebrow::before {
      content: '';
      display: block;
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: var(--accent);
      animation: pulse 2s ease-in-out infinite;
    }
