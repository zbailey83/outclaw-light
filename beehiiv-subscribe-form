  </div>

</div>

<!-- ═══════════════════════════════════
     JAVASCRIPT — beehiiv API subscribe
     ═══════════════════════════════════ -->
<script>
  const emailInput = document.getElementById('bh-email');
  const btn        = document.getElementById('bh-btn');
  const statusEl   = document.getElementById('bh-status');

  function showStatus(type, icon, msg) {
    statusEl.className = `status ${type} visible`;
    statusEl.querySelector('.status-icon').textContent = icon;
    statusEl.querySelector('.status-msg').textContent  = msg;
  }

  function isValidEmail(v) {
    return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(v.trim());
  }

  async function subscribe() {
    const email = emailInput.value.trim();

    if (!email)            return showStatus('error', '⚠️', 'Please enter your email address.');
    if (!isValidEmail(email)) return showStatus('error', '⚠️', 'Please enter a valid email address.');

    // ── loading state ──
    btn.disabled = true;
    btn.classList.add('loading');
    statusEl.className = 'status';

    try {
      const res = await fetch(
        `https://api.beehiiv.com/v2/publications/${BEEHIIV_PUB_ID}/subscriptions`,
        {
          method:  'POST',
          headers: {
            'Content-Type':  'application/json',
            'Authorization': `Bearer ${BEEHIIV_API_KEY}`,
          },
          body: JSON.stringify({
            email,
            reactivate_existing: true,
            send_welcome_email:  true,
            utm_source: UTM_SOURCE,
            utm_medium: 'website',
          }),
        }
      );

      const data = await res.json();

      if (res.ok) {
        // ✅ success
        emailInput.value = '';
        btn.textContent  = '✓ Subscribed';
        btn.style.background = '#2dffb0';
        showStatus('success', '🎉', 'You\'re in! Check your inbox to confirm.');
      } else {
        // API returned an error (e.g. invalid pub ID)
        const msg = data?.message || 'Something went wrong. Please try again.';
        showStatus('error', '✕', msg);
        btn.disabled = false;
        btn.classList.remove('loading');
      }

    } catch (err) {
      // Network / CORS error — see note below
      showStatus('error', '✕', 'Could not connect. Check your API key & publication ID.');
      console.error('[beehiiv embed]', err);
      btn.disabled = false;
      btn.classList.remove('loading');
    }
  }

  btn.addEventListener('click', subscribe);
  emailInput.addEventListener('keydown', e => { if (e.key === 'Enter') subscribe(); });
</script>

